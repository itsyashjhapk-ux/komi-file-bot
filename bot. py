from pyrogram import Client, filters
from pyrogram.types import InlineKeyboardMarkup, InlineKeyboardButton
import config

bot = Client(
    "KomiBot",
    api_id=config.API_ID,
    api_hash=config.API_HASH,
    bot_token=config.BOT_TOKEN
)

START_BUTTONS = InlineKeyboardMarkup(
    [
        [
            InlineKeyboardButton("🔗 Short Link", callback_data="shortlink"),
            InlineKeyboardButton("📖 Tutorial", callback_data="tutorial")
        ],
        [
            InlineKeyboardButton("💰 Premium", callback_data="premium")
        ]
    ]
)

@bot.on_message(filters.command("start"))
async def start(client, message):

    text = f"""
👋 Welcome to **Komi Link Provider Bot**

Send me any link and I will convert it into a **short link**.

⚡ Fast
🔒 Secure
🚀 Unlimited

Created for easy link sharing.
"""

    await message.reply_photo(
        photo=config.START_PIC,
        caption=text,
        reply_markup=START_BUTTONS
    )

@bot.on_callback_query(filters.regex("shortlink"))
async def shortlink(client, query):

    await query.message.reply_text(
        "📩 Send your link now.\n\nExample:\nhttps://google.com"
    )

@bot.on_callback_query(filters.regex("tutorial"))
async def tutorial(client, query):

    await query.message.reply_text(
        "📖 Tutorial:\n\n1️⃣ Click Short Link\n2️⃣ Send your URL\n3️⃣ Get shortened link"
    )

@bot.on_callback_query(filters.regex("premium"))
async def premium(client, query):

    await query.message.reply_text(
        "💰 Premium Features:\n\n• Faster links\n• Custom domain\n• No limits\n\nContact admin."
    )

@bot.on_message(filters.text & ~filters.command(["start"]))
async def shortener(client, message):

    link = message.text

    short = f"https://{config.BOT_USERNAME}.xyz/{message.id}"

    await message.reply_text(
        f"✅ Your Short Link:\n\n{short}"
    )

bot.run()
